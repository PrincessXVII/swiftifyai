YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_yandex_folder_id_here
# optional override:
# YANDEX_MODEL_URI=gpt://<folder_id>/yandexgpt-lite
BACKEND_AUTH_TOKEN=your_backend_token_here
VITE_API_BASE_URL=http://localhost:8787
VITE_BACKEND_AUTH_TOKEN=your_backend_token_here

# Пробный тариф (server/index.mjs): суммарно символов пользовательского ввода за UTC-день; SwiftifyPlus без лимита
# TRIAL_DAILY_CHARS=5000
# MAX_FIELD_CHARS=32000

# Продакшен: канонический URL фронта (OAuth redirect). Локально не нужен.
# VITE_SITE_URL=https://your-domain.com

# Ссылка «Перейти на Plus» в чате (новая вкладка). Если не задана — открывается личный кабинет.
# VITE_PLUS_UPGRADE_URL=https://your-domain.com/plus

# Supabase — https://supabase.com/dashboard
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Бэкенд (server/index.mjs): разрешённые Origin для CORS, через запятую
# CORS_ORIGIN=https://your-domain.com

# Supabase Service Role — только на сервере, для выдачи Plus после оплаты (никогда в VITE_*).
# SUPABASE_SERVICE_ROLE_KEY=

# ЮKassa — https://yookassa.ru/ (магазин → ключи API). Публичный URL возврата после оплаты.
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# PUBLIC_APP_URL=https://your-domain.com
# PLUS_PRICE_RUB=99.00
# PLUS_PERIOD_DAYS=30
# PLUS_PAYMENT_DESCRIPTION=Подписка SwiftifyPlus, 30 дней
# В личном кабинете ЮKassa укажите HTTP-уведомления на:
# https://your-api-domain/api/billing/yookassa/webhook

# Подпись в ЛК (опционально): текст цены на фронте
# VITE_PLUS_PRICE_LABEL=99 ₽ за 30 дней
