YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_yandex_folder_id_here
# optional override:
# YANDEX_MODEL_URI=gpt://<folder_id>/yandexgpt-lite
BACKEND_AUTH_TOKEN=your_backend_token_here
VITE_API_BASE_URL=http://localhost:8787
VITE_BACKEND_AUTH_TOKEN=your_backend_token_here

# Пробный тариф (server/index.mjs): суммарно символов пользовательского ввода за UTC-день; SwiftifyPro без лимита
# TRIAL_DAILY_CHARS=5000
# MAX_FIELD_CHARS=32000

# Продакшен: канонический URL фронта (OAuth redirect). Локально не нужен.
# VITE_SITE_URL=https://your-domain.com

# Supabase — https://supabase.com/dashboard
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Бэкенд (server/index.mjs): разрешённые Origin для CORS, через запятую
# CORS_ORIGIN=https://your-domain.com
